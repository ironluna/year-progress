<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>年度进度</title>
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body {
    display: flex; justify-content: center; align-items: center;
    min-height: 100vh;
    background: #f0f2f0; color: #4a5a4a;
    font-family: -apple-system, "Segoe UI", Roboto, "Helvetica Neue", sans-serif;
  }
  .card {
    background: #ffffff; border-radius: 16px; padding: 40px 48px;
    width: 420px; max-width: 90vw;
    box-shadow: 0 4px 20px rgba(100,120,100,.12);
    border: 1px solid #e0e8e0;
  }
  h1 { font-size: 18px; font-weight: 500; margin-bottom: 24px; color: #8a9a8a; }
  .percent {
    font-size: 64px; font-weight: 700; letter-spacing: -2px;
    color: #7ab893;
  }
  .percent .unit { font-size: 28px; font-weight: 500; color: #a0c4a0; }
  .bar-wrap {
    width: 100%; height: 12px; background: #e8ede8;
    border-radius: 6px; margin: 24px 0 20px; overflow: hidden;
  }
  .bar {
    height: 100%; border-radius: 6px;
    background: linear-gradient(90deg, #a8d8b9, #7ab893);
    transition: width .6s ease;
  }
  .info { font-size: 14px; color: #8a9a8a; line-height: 1.8; }
  .info span { color: #5a7a5a; font-weight: 600; }
</style>
</head>
<body>
<div class="card">
  <h1 id="yearTitle"></h1>
  <div class="percent" id="pct"></div>
  <div class="bar-wrap"><div class="bar" id="bar"></div></div>
  <div class="info" id="info"></div>
</div>
<script>
function update() {
  const now = new Date();
  const year = now.getFullYear();
  const start = new Date(year, 0, 1);
  const end = new Date(year + 1, 0, 1);
  const totalDays = (end - start) / 864e5;
  const elapsed = (now - start) / 864e5;
  const pct = (elapsed / totalDays) * 100;
  const dayOfYear = Math.ceil(elapsed);

  document.getElementById('yearTitle').textContent = year + ' 年度进度';
  document.getElementById('pct').innerHTML = pct.toFixed(1) + '<span class="unit">%</span>';
  document.getElementById('bar').style.width = pct.toFixed(1) + '%';
  document.getElementById('info').innerHTML =
    '今天是 ' + year + ' 年第 <span>' + dayOfYear + '</span> 天，' +
    '全年共 <span>' + totalDays + '</span> 天<br>' +
    '已过去 <span>' + dayOfYear + '</span> 天，' +
    '剩余 <span>' + (totalDays - dayOfYear) + '</span> 天';
}
update();
setInterval(update, 60000);
</script>
</body>
</html>